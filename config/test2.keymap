#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include "../../../config/keys_sv.h"

/* Layer Definitions */
#define BASE 0
#define NAV  1
#define SYM  2
#define NUM  3
#define FUN  4
#define WIN  5
#define MED  6

/ {
    behaviors {
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&kp>;
        };
    };

    macros {
        /* Common Python/Programming arrows */
        arrow: arrow {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SV_MINUS &kp SV_GT>;
            label = "ARROW";
        };
        fat_arrow: fat_arrow {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SV_EQUAL &kp SV_GT>;
            label = "FAT_ARROW";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        /* 
         * BASE Layer: QWERTY with Home Row Mods
         * Left Thumbs:  WIN/ESC,  MED/TAB,   NAV/SPACE
         * Right Thumbs: SYM/RET,  NUM/BSPC,  FUN/DEL
         */
        default_layer {
            bindings = <
                &kp Q       &kp W       &kp E       &kp R       &kp T         &kp Y       &kp U       &kp I       &kp O       &kp P
                &hm LGUI A  &hm LALT S  &hm LCTRL D &hm LSHFT F &kp G         &kp H       &hm RSHFT J &hm RCTRL K &hm RALT L  &hm RGUI SV_O_UMLAUT
                &kp Z       &kp X       &kp C       &kp V       &kp B         &kp N       &kp M       &kp COMMA   &kp DOT     &kp SV_MINUS
                                        &lt WIN ESC &lt MED TAB &lt NAV SPACE &lt SYM RET &lt NUM BSPC &lt FUN DEL
            >;
        };

        /* 
         * NAV Layer: Vim Navigation & Clipboard
         * Accessed via Inner Left Thumb (Space)
         */
        nav_layer {
            bindings = <
                &trans      &trans      &trans      &trans      &trans        &kp HOME    &kp PG_DN   &kp PG_UP   &kp END     &trans
                &kp LGUI    &kp LALT    &kp LCTRL   &kp LSHFT   &trans        &kp LEFT    &kp DOWN    &kp UP      &kp RIGHT   &trans
                &kp LG(Z)   &kp LG(X)   &kp LG(C)   &kp LG(V)   &trans        &trans      &trans      &trans      &trans      &trans
                                        &trans      &trans      &trans        &trans      &trans      &trans
            >;
        };

        /* 
         * SYM Layer: Python Optimized (Swedish Keys)
         * Accessed via Inner Right Thumb (Enter)
         */
        sym_layer {
            bindings = <
                &kp SV_EXCL &kp SV_AT   &kp SV_HASH &kp SV_DLLR &kp SV_PRCNT  &kp SV_CARET &kp SV_AMPS &kp SV_ASTRK &kp SV_LPAR &kp SV_RPAR
                &kp SV_GRAVE &kp SV_SQT &kp SV_DQT  &kp SV_LBRC &kp SV_RBRC   &kp SV_EQUAL &kp SV_LPAR &kp SV_RPAR &kp SV_LBKT &kp SV_RBKT
                &kp SV_BSLH &kp SV_PIPE &kp SV_LT   &kp SV_GT   &arrow        &kp SV_UNDER &kp SV_PLUS &kp SV_MINUS &kp SV_COLON &kp SV_SEMI
                                        &trans      &trans      &trans        &trans      &trans      &trans
            >;
        };

        /* 
         * NUM Layer: Numpad
         * Accessed via Middle Right Thumb (Backspace)
         */
        num_layer {
            bindings = <
                &trans      &trans      &trans      &trans      &trans        &kp SV_PLUS &kp N7      &kp N8      &kp N9      &kp SV_ASTRK
                &kp LGUI    &kp LALT    &kp LCTRL   &kp LSHFT   &trans        &kp SV_MINUS &kp N4     &kp N5      &kp N6      &kp SV_FSLH
                &trans      &trans      &trans      &trans      &trans        &kp N0      &kp N1      &kp N2      &kp N3      &kp DOT
                                        &trans      &trans      &trans        &trans      &trans      &trans
            >;
        };

        /* 
         * FUN Layer: F-Keys & System
         * Accessed via Outer Right Thumb (Delete)
         */
        fun_layer {
            bindings = <
                &kp F12     &kp F7      &kp F8      &kp F9      &kp PSCRN     &trans      &trans      &trans      &trans      &trans
                &kp F11     &kp F4      &kp F5      &kp F6      &trans        &trans      &kp LSHFT   &kp LCTRL   &kp LALT    &kp LGUI
                &kp F10     &kp F1      &kp F2      &kp F3      &trans        &trans      &trans      &trans      &trans      &trans
                                        &trans      &trans      &trans        &trans      &trans      &trans
            >;
        };

        /* 
         * WIN Layer: Window Management & Workspaces
         * Accessed via Outer Left Thumb (Esc)
         */
        win_layer {
            bindings = <
                &trans      &kp LG(N7)  &kp LG(N8)  &kp LG(N9)  &trans        &trans      &trans      &trans      &trans      &trans
                &kp LGUI    &kp LG(N4)  &kp LG(N5)  &kp LG(N6)  &trans        &trans      &trans      &trans      &trans      &trans
                &trans      &kp LG(N1)  &kp LG(N2)  &kp LG(N3)  &trans        &trans      &trans      &trans      &trans      &trans
                                        &trans      &trans      &trans        &trans      &trans      &trans
            >;
        };

        /* 
         * MED Layer: Media & Bluetooth
         * Accessed via Middle Left Thumb (Tab)
         */
        media_layer {
            bindings = <
                &bootloader &trans      &trans      &trans      &trans        &trans      &trans      &trans      &trans      &bootloader
                &bt BT_CLR  &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &trans     &kp C_PREV  &kp C_VOL_DN &kp C_VOL_UP &kp C_NEXT &trans
                &sys_reset  &trans      &trans      &trans      &trans        &trans      &kp C_PP    &kp C_MUTE  &trans      &sys_reset
                                        &trans      &trans      &trans        &trans      &trans      &trans
            >;
        };
    };
};
