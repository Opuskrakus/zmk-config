/*
 * Skeletyl Keymap - Swedish Developer Edition
 * Optimized for Python, terminal work, and macOS/Linux
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include "../../../config/keys_sv.h"

/ {
    behaviors {
        // Home row mods - optimized timing for typing comfort
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <150>;
            require-prior-idle-ms = <125>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // Layer 0: Base QWERTY with Home Row Mods
        default_layer {
            bindings = <
                &kp SV_Q         &kp SV_W        &kp SV_E        &kp SV_R        &kp SV_T            &kp SV_Y        &kp SV_U        &kp SV_I        &kp SV_O        &kp SV_P
                &hm LSHFT SV_A   &hm LCTRL SV_S  &hm LALT SV_D   &hm LGUI SV_F   &kp SV_G            &kp SV_H        &hm RGUI SV_J   &hm RALT SV_K   &hm RCTRL SV_L  &hm RSHFT SV_O_UMLAUT
                &kp SV_Z         &kp SV_X        &kp SV_C        &kp SV_V        &kp SV_B            &kp SV_N        &kp SV_M        &kp SV_COMMA    &kp SV_DOT      &kp SV_MINUS
                                                 &kp ESC         &lt 1 SPACE     &kp TAB             &lt 2 RET       &lt 3 BSPC      &kp DEL
            >;
        };

        // Layer 1: Symbol Layer (Programming Focus)
        symbol_layer {
            bindings = <
                &kp SV_HASH      &kp SV_AT       &kp SV_LBKT     &kp SV_RBKT     &kp SV_PERCENT      &kp SV_AMPS     &kp SV_ASTRK    &kp SV_EQUAL    &kp SV_PLUS     &kp SV_PIPE
                &kp SV_EXCL      &kp SV_DOLLAR   &kp SV_LPAR     &kp SV_RPAR     &kp SV_GRAVE        &kp SV_BSLH     &kp SV_SQT      &kp SV_DQT      &kp SV_COLON    &kp SV_SEMI
                &kp SV_TILDE     &kp SV_CARET    &kp SV_LBRC     &kp SV_RBRC     &kp SV_UNDER        &kp SV_LT       &kp SV_GT       &kp SV_FSLH     &kp SV_QMARK    &kp SV_A_RING
                                                 &trans          &trans          &trans              &kp SV_EQUAL    &kp SV_UNDER    &kp SV_MINUS
            >;
        };

        // Layer 2: Number + Function Layer
        number_layer {
            bindings = <
                &kp F1           &kp F2          &kp F3          &kp F4          &kp F5              &kp F6          &kp SV_N7       &kp SV_N8       &kp SV_N9       &kp SV_ASTRK
                &kp F7           &kp F8          &kp F9          &kp F10         &kp F11             &kp F12         &kp SV_N4       &kp SV_N5       &kp SV_N6       &kp SV_PLUS
                &none            &none           &none           &none           &none               &kp SV_N0       &kp SV_N1       &kp SV_N2       &kp SV_N3       &kp SV_FSLH
                                                 &trans          &trans          &trans              &trans          &kp SV_N0       &kp SV_DOT
            >;
        };

        // Layer 3: Navigation + System Layer
        navigation_layer {
            bindings = <
                &kp C_VOL_UP     &kp C_BRI_UP    &kp C_PREV      &kp C_PP        &kp C_NEXT          &kp PG_UP       &kp HOME        &kp UP          &kp END         &none
                &kp C_VOL_DN     &kp C_BRI_DN    &kp C_MUTE      &none           &none               &kp PG_DN       &kp LEFT        &kp DOWN        &kp RIGHT       &none
                &bt BT_CLR       &bt BT_SEL 0    &bt BT_SEL 1    &bt BT_SEL 2    &bt BT_SEL 3        &none           &none           &none           &none           &none
                                                 &trans          &trans          &trans              &trans          &trans          &trans
            >;
        };
    };
};





Skeletyl Swedish Developer Keymap
Overview
Creating a 36-key keymap for boards/shields/skeletyl/skeletyl.keymap tailored for Python and terminal work, using Swedish key definitions from config/keys_sv.h.

Layer Structure
Hold Left Thumb 1
Hold Right Thumb 1
Hold Right Thumb 2
Base Layer: QWERTY + Home Row Mods
Symbol Layer: Programming Symbols
Number Layer: Numpad + Function Keys
Navigation Layer: Vim + System
Layer Breakdown
Layer 0: Base (QWERTY with Home Row Mods)
Top row: Q W E R T | Y U I O P
Home row: A(Shift) S(Ctrl) D(Alt) F(GUI) G | H J(GUI) K(Alt) L(Ctrl) Ö(Shift)
Bottom row: Z X C V B | N M , . -
Thumbs: ESC, SPACE(tap)/SYM(hold), TAB | ENTER(tap)/NUM(hold), BSPC(tap)/NAV(hold), DEL
Home row mods activate when held, type letters when tapped

Layer 1: Symbol Layer (Python/Programming Focus)
Optimized for Python, shell scripts, and common programming symbols:

Left hand: Swedish brackets/braces [{ }], parens (), pipe |, backslash `\`
Right hand: Comparison ops < > =, quotes ' ", operators + - * /
Strategic placement: 
Brackets on left index/middle fingers (frequent in Python)
Underscores accessible (Python naming)
Swedish-specific symbols using SV_ definitions
Layer 2: Number + Function Layer
Right hand numpad (indices/middle fingers):
7 8 9
4 5 6
1 2 3
    0
Left hand: F1-F10 function keys for terminal shortcuts
Extras: Mathematical operators adjacent to numpad
Layer 3: Navigation Layer
Right hand home row: Vim-style H(left) J(down) K(up) L(right)
Additional nav: Home, End, PgUp, PgDn
Media/System: Volume, brightness, media controls
Utility: Screenshot keys, window management helpers
Implementation Details
Include Swedish keys: Add #include "../../../config/keys_sv.h" to access SV_ definitions
Configure behaviors: Set up home row mod timing (tapping-term, quick-tap-ms)
Use SV_ macros: All symbols use Swedish layout (e.g., &kp SV_LBKT for [)
Layer-tap combos: 
Space = tap space, hold for Symbol layer
Enter = tap enter, hold for Number layer
Backspace = tap backspace, hold for Nav layer
Key Programming Symbols Covered
Brackets: [], {}, ()
Operators: +-*/=<>
Python essentials: _ (underscore), : (colon), ->, **
Shell: |, &, $, ~, `` ` ``
Strings: ', "
Comments: #
Files Modified
boards/shields/skeletyl/skeletyl.keymap - Complete rewrite with 4 layers
Testing Recommendations
After implementation, test:

Home row mod timing (adjust tapping-term if needed)
Swedish symbol output matches OS expectations
Layer switching feels natural for your workflow
Common Python patterns (def, class, f-strings, list comprehensions)