// Example 6: Gaming/Productivity Hybrid
// Philosophy: Left hand gaming-ready (WASD accessible), right hand for typing
// Focus: Fast reactions with left, comfortable typing with both
// Thumb Strategy: Left heavy for rapid actions, right for modifiers

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

#define BASE 0
#define GAME 1
#define NUM  2
#define FN   3

/ {
    keymap {
        compatible = "zmk,keymap";

        base_layer {
            bindings = <
    // ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
         &kp Q         &kp W         &kp E         &kp R         &kp T             &kp Y         &kp U         &kp I         &kp O         &kp P
    // ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
         &mt LGUI A    &mt LALT S    &mt LCTRL D   &mt LSHFT F   &kp G             &kp H         &mt RSHFT J   &mt RCTRL K   &mt RALT L    &mt RGUI SEMI
    // ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
         &kp Z         &kp X         &kp C         &kp V         &kp B             &kp N         &kp M         &kp COMMA     &kp DOT       &kp FSLH
    // ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┴─────────────┴─────────────╯
                                     &lt FN TAB    &lt GAME ESC  &lt NUM BSPC      &kp SPACE     &kp LSHFT     &kp RET
    //                               ╰─────────────┴─────────────┴─────────────╯   ╰─────────────┴─────────────┴─────────────╯
            >;
        };

        game_layer {
            // Easy number access for gaming, nav on right
            bindings = <
         &kp N1        &kp N2        &kp N3        &kp N4        &kp N5            &kp HOME      &kp PG_DN     &kp PG_UP     &kp END       &none
         &kp TAB       &kp Q         &kp W         &kp E         &kp R             &kp LEFT      &kp DOWN      &kp UP        &kp RIGHT     &none
         &kp LSHFT     &kp A         &kp S         &kp D         &kp F             &none         &none         &none         &none         &none
                                     &kp LCTRL     &kp SPACE     &kp LALT          &trans        &trans        &trans
            >;
        };

        num_layer {
            bindings = <
         &kp N1        &kp N2        &kp N3        &kp N4        &kp N5            &kp N6        &kp N7        &kp N8        &kp N9        &kp N0
         &kp EXCL      &kp AT        &kp HASH      &kp DLLR      &kp PRCNT         &kp CARET     &kp AMPS      &kp STAR      &kp MINUS     &kp EQUAL
         &kp GRAVE     &kp TILDE     &kp LBKT      &kp RBKT      &kp BSLH          &kp LPAR      &kp RPAR      &kp LBRC      &kp RBRC      &kp PIPE
                                     &trans        &trans        &trans            &trans        &trans        &trans
            >;
        };

        fn_layer {
            bindings = <
         &kp F1        &kp F2        &kp F3        &kp F4        &kp F5            &kp F6        &kp F7        &kp F8        &kp F9        &kp F10
         &kp LGUI      &kp LALT      &kp LCTRL     &kp LSHFT     &kp F11           &kp F12       &none         &none         &none         &none
         &kp LC(Z)     &kp LC(X)     &kp LC(C)     &kp LC(V)     &kp LC(Y)         &none         &none         &none         &none         &none
                                     &trans        &trans        &trans            &trans        &trans        &trans
            >;
        };
    };
};
