// Example 3: One-Handed Left Dominance
// Philosophy: Maximize left hand capability for mouse/pen use with right
// Focus: All essential keys accessible from left hand + left thumb cluster
// Thumb Strategy: Right thumbs carry critical functions (space, enter, shift)

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

#define BASE 0
#define NAV  1
#define NUM  2
#define SYM  3

/ {
    keymap {
        compatible = "zmk,keymap";

        base_layer {
            bindings = <
    // ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
         &kp Q         &kp W         &kp E         &kp R         &kp T             &kp Y         &kp U         &kp I         &kp O         &kp P
    // ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
         &mt LGUI A    &mt LALT S    &mt LCTRL D   &mt LSHFT F   &kp G             &kp H         &kp J         &kp K         &kp L         &kp SEMI
    // ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
         &kp Z         &kp X         &kp C         &kp V         &kp B             &kp N         &kp M         &kp COMMA     &kp DOT       &kp FSLH
    // ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┴─────────────┴─────────────╯
                                     &lt NUM TAB   &lt SYM ESC   &lt NAV BSPC      &kp SPACE     &kp LSHFT     &kp RET
    //                               ╰─────────────┴─────────────┴─────────────╯   ╰─────────────┴─────────────┴─────────────╯
            >;
        };

        nav_layer {
            bindings = <
         &kp ESC       &kp TAB       &kp LC(F)     &kp LC(S)     &kp LC(Z)         &kp HOME      &kp PG_DN     &kp PG_UP     &kp END       &kp INS
         &kp LGUI      &kp LALT      &kp LCTRL     &kp LSHFT     &kp LC(Y)         &kp LEFT      &kp DOWN      &kp UP        &kp RIGHT     &none
         &kp LC(X)     &kp LC(C)     &kp LC(V)     &kp LC(A)     &kp DEL           &none         &none         &none         &none         &none
                                     &trans        &trans        &trans            &trans        &trans        &trans
            >;
        };

        num_layer {
            bindings = <
         &kp N1        &kp N2        &kp N3        &kp N4        &kp N5            &kp N6        &kp N7        &kp N8        &kp N9        &kp N0
         &kp LGUI      &kp LALT      &kp LCTRL     &kp LSHFT     &kp F11           &kp MINUS     &kp EQUAL     &kp LBKT      &kp RBKT      &kp BSLH
         &kp F1        &kp F2        &kp F3        &kp F4        &kp F5            &kp F6        &kp F7        &kp F8        &kp F9        &kp F10
                                     &trans        &trans        &trans            &trans        &trans        &trans
            >;
        };

        sym_layer {
            bindings = <
         &kp EXCL      &kp AT        &kp HASH      &kp DLLR      &kp PRCNT         &kp CARET     &kp AMPS      &kp STAR      &kp LPAR      &kp RPAR
         &kp LGUI      &kp LALT      &kp LCTRL     &kp LSHFT     &kp SQT           &kp DQT       &kp LBKT      &kp RBKT      &kp LBRC      &kp RBRC
         &kp GRAVE     &kp TILDE     &kp UNDER     &kp MINUS     &kp PLUS          &kp EQUAL     &kp LT        &kp GT        &kp PIPE      &kp BSLH
                                     &trans        &trans        &trans            &trans        &trans        &trans
            >;
        };
    };
};
