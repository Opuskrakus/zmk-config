// Example 8: Alternating Hands Priority
// Philosophy: Maximize hand alternation for speed and comfort
// Focus: Common bigrams split across hands, roll-friendly sequences
// Thumb Strategy: Symmetric - each thumb cluster mirrors the other

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

#define BASE 0
#define NAV  1
#define NUM  2
#define SYM  3

/ {
    keymap {
        compatible = "zmk,keymap";

        base_layer {
            bindings = <
    // ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
         &kp Q         &kp W         &kp D         &kp F         &kp K             &kp J         &kp U         &kp R         &kp L         &kp SEMI
    // ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
         &mt LGUI A    &mt LALT S    &mt LCTRL E   &mt LSHFT T   &kp G             &kp Y         &mt RSHFT N   &mt RCTRL I   &mt RALT O    &mt RGUI H
    // ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
         &kp Z         &kp X         &kp C         &kp V         &kp B             &kp P         &kp M         &kp COMMA     &kp DOT       &kp FSLH
    // ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┴─────────────┴─────────────╯
                                     &lt NUM TAB   &lt NAV BSPC  &kp ESC           &kp RET       &lt SYM SPACE &kp DEL
    //                               ╰─────────────┴─────────────┴─────────────╯   ╰─────────────┴─────────────┴─────────────╯
            >;
        };

        nav_layer {
            bindings = <
         &none         &none         &none         &none         &none             &kp HOME      &kp PG_DN     &kp PG_UP     &kp END       &kp INS
         &kp LGUI      &kp LALT      &kp LCTRL     &kp LSHFT     &none             &kp LEFT      &kp DOWN      &kp UP        &kp RIGHT     &kp CAPS
         &kp LC(Z)     &kp LC(X)     &kp LC(C)     &kp LC(V)     &kp LC(Y)         &none         &none         &none         &none         &none
                                     &trans        &trans        &trans            &trans        &trans        &trans
            >;
        };

        num_layer {
            bindings = <
         &kp N1        &kp N2        &kp N3        &kp N4        &kp N5            &kp N6        &kp N7        &kp N8        &kp N9        &kp N0
         &kp LGUI      &kp LALT      &kp LCTRL     &kp LSHFT     &kp F11           &kp F12       &kp RSHFT     &kp RCTRL     &kp RALT      &kp RGUI
         &kp F1        &kp F2        &kp F3        &kp F4        &kp F5            &kp F6        &kp F7        &kp F8        &kp F9        &kp F10
                                     &trans        &trans        &trans            &kp N0        &trans        &trans
            >;
        };

        sym_layer {
            bindings = <
         &kp EXCL      &kp AT        &kp HASH      &kp DLLR      &kp PRCNT         &kp CARET     &kp AMPS      &kp STAR      &kp LPAR      &kp RPAR
         &kp MINUS     &kp EQUAL     &kp LBKT      &kp RBKT      &kp BSLH          &kp SQT       &kp DQT       &kp LBRC      &kp RBRC      &kp PIPE
         &kp GRAVE     &kp TILDE     &kp UNDER     &kp PLUS      &none             &none         &kp LT        &kp GT        &kp QMARK     &kp COLON
                                     &trans        &trans        &trans            &trans        &trans        &trans
            >;
        };
    };
};
